# ----------------------------
# Runtime Profile
# ----------------------------
APP_ENV_PROFILE=dev
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ----------------------------
# LLM
# ----------------------------
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_PROXY=
LLM_MODEL=deepseek-chat
LLM_MODEL_V3=deepseek-chat
LLM_MODEL_R1=deepseek-reasoner
LLM_MODEL_V3_FALLBACK=
LLM_MODEL_R1_FALLBACK=
LLM_TIMEOUT_MS=480000
LLM_MAX_TOKENS_CAP=12288
MAX_OUTPUT_TOKENS=12288
GENERATE_MAX_TOKENS=4096
FAST_GENERATE=0

# ----------------------------
# Generate Pipeline Budgets
# ----------------------------
GEN_TOTAL_BUDGET_MS=480000
REASON_MAX_MS=180000
GENERATE_MAX_MS=360000
CONTINUE_MAX_MS=90000
DRAFT_MAX_MS=180000
SAFETY_MARGIN_MS=15000
GENERATE_STAGE_MAX_ATTEMPTS=2
MAX_FALLBACK_ATTEMPTS_PER_JOB=2

# ----------------------------
# Revise Pipeline Budgets
# ----------------------------
REVISE_TOTAL_BUDGET_MS=180000
REVISE_APPLY_MAX_MS=240000
REVISE_CONSISTENCY_MAX_MS=160000
REVISE_CONSISTENCY_MAX_ATTEMPTS=2
REVISE_SYNC_MAX_DOC_LENGTH=6000
REVISE_SYNC_MAX_ANNOTATIONS=3

# ----------------------------
# Job Retention
# ----------------------------
GENERATE_JOB_TTL_MS=1800000
MAX_GENERATE_JOBS=200
REVISE_JOB_TTL_MS=1800000
MAX_REVISE_JOBS=300

# ----------------------------
# Auth
# ----------------------------
AUTH_REQUIRED=1
JWT_SECRET=replace-with-strong-random-secret
ACCESS_TOKEN_TTL_MS=900000
REFRESH_TOKEN_TTL_MS=2592000000
PASSWORD_RESET_CODE_TTL_MS=900000
PASSWORD_RESET_RESEND_COOLDOWN_MS=60000
PASSWORD_RESET_MAX_VERIFY_ATTEMPTS=8
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=900000
PASSWORD_RESET_FORGOT_MAX_PER_WINDOW=5
PASSWORD_RESET_VERIFY_MAX_PER_WINDOW=20
RESEND_API_KEY=
MAIL_FROM=noreply@reqmd.com
RESET_PASSWORD_URL_BASE=https://www.reqmd.com

# ----------------------------
# Rate Limit (per window)
# ----------------------------
RATE_LIMIT_WINDOW_MS=60000
DEFAULT_RATE_LIMIT_PER_WINDOW=60
WRITE_RATE_LIMIT_PER_WINDOW=30
STATUS_POLL_RATE_LIMIT_PER_WINDOW=240
AUTH_BILLING_RATE_LIMIT_PER_WINDOW=60

# ----------------------------
# Trial / Quota
# ----------------------------
ANON_QUOTA_ENFORCED=0
ANON_TRIAL_TOKEN_TTL_MS=1800000
ANON_TRIAL_MAX_PREVIEW_CHARS=20000

# ----------------------------
# Billing / Payment
# ----------------------------
PADDLE_ENV=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID_CNY=
PADDLE_PRICE_ID_USD=
PADDLE_SUCCESS_URL=https://www.requirement-web.ai/?checkout=success
PADDLE_CANCEL_URL=https://www.requirement-web.ai/?checkout=cancel

# ----------------------------
# Observability
# ----------------------------
STRUCTURED_LOG=1
SENTRY_DSN=
BACKUP_ENABLED=1
BACKUP_INTERVAL_MS=86400000
BACKUP_RETENTION_DAYS=14

# ----------------------------
# Frontend (Vite)
# ----------------------------
VITE_API_BASE=/api
VITE_API_TIMEOUT_MS=300000
VITE_CLARIFY_TIMEOUT_MS=45000
VITE_CREATE_JOB_TIMEOUT_MS=15000
VITE_JOB_STATUS_TIMEOUT_MS=15000
VITE_GENERATE_MAX_WAIT_MS=540000
VITE_HOME_STATE_TTL_MS=1200000
