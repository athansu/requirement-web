# 必填：OpenAI 兼容 API Key（如 DeepSeek）
LLM_API_KEY=

# 可选：API 地址，默认 DeepSeek
LLM_BASE_URL=https://api.deepseek.com

# 可选：默认模型（未指定时使用）
LLM_MODEL=deepseek-chat

# 四阶段模型（可选）
# Phase1 提问、Phase3 生成 使用 V3
# Phase2 推理、Phase4 修订 使用 R1
LLM_MODEL_V3=deepseek-chat
LLM_MODEL_R1=deepseek-reasoner

# 可选：当主模型超时/网络错误/5xx时使用备用模型
# LLM_MODEL_V3_FALLBACK=
# LLM_MODEL_R1_FALLBACK=

# 认证与安全（生产必配）
# AUTH_REQUIRED=1
# JWT_SECRET=replace-with-a-long-random-secret
# ACCESS_TOKEN_TTL_MS=900000
# REFRESH_TOKEN_TTL_MS=2592000000
# RATE_LIMIT_WINDOW_MS=60000
# DEFAULT_RATE_LIMIT_PER_WINDOW=60

# 可选：结构化日志与监控
# STRUCTURED_LOG=1
# SENTRY_DSN=
# ANON_TRIAL_TOKEN_TTL_MS=1800000

# 可选：HTTP 代理（如需科学上网）
# LLM_PROXY=http://127.0.0.1:7890
# 或 HTTPS_PROXY=http://127.0.0.1:7890

# 可选：单次模型请求超时，单位毫秒，默认 300000
# LLM_TIMEOUT_MS=300000

# 可选：阶段超时（用于生成链路提速与降级）
# GEN_TOTAL_BUDGET_MS=480000
# REASON_MAX_MS=90000
# GENERATE_MAX_MS=180000
# CONTINUE_MAX_MS=90000
# DRAFT_MAX_MS=120000
# SAFETY_MARGIN_MS=15000
# MAX_FALLBACK_ATTEMPTS_PER_JOB=2
# GENERATE_STAGE_MAX_ATTEMPTS=2

# 修订任务预算
# REVISE_TOTAL_BUDGET_MS=180000
# REVISE_APPLY_MAX_MS=120000
# REVISE_CONSISTENCY_MAX_MS=70000
# REVISE_CONSISTENCY_MAX_ATTEMPTS=2

# 可选：允许跨域访问的来源，多个值用逗号分隔
# 仅在前后端分开部署时需要配置
# CORS_ORIGIN=https://your-frontend.example.com

# 支付（Paddle MoR）
# PADDLE_ENV=sandbox
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# PADDLE_PRICE_ID_CNY=
# PADDLE_PRICE_ID_USD=
# PADDLE_SUCCESS_URL=https://www.requirement-web.ai/?checkout=success
# PADDLE_CANCEL_URL=https://www.requirement-web.ai/?checkout=cancel

# 可选：端口，默认 3001
# PORT=3001

# 可选：快速生成（跳过推理步骤，仅一次调用，约快一倍）
# FAST_GENERATE=1

# 可选：生成文档最大 token 数，越小响应越快、文档越短（默认 4096）
# GENERATE_MAX_TOKENS=4096

# 可选：当生成结果疑似未完成时自动续写，默认开启
# AUTO_CONTINUE_INCOMPLETE=1

# 可选：生成任务队列配置（默认内存队列）
# GENERATE_JOB_TTL_MS=1800000
# MAX_GENERATE_JOBS=200
# REVISE_JOB_TTL_MS=1800000
# MAX_REVISE_JOBS=300
